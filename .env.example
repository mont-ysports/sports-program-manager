# =============================================================
#  2026 Children Vacation Sports Program — Environment Config
# =============================================================

# ── Google Apps Script ──────────────────────────────────────
# The URL you receive after deploying your Apps Script Web App
# (Step 4 of the README setup walkthrough)
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# ── Staff Portal ─────────────────────────────────────────────
# A bcrypt hash of the staff portal password.
# Generate one at: https://bcrypt-generator.com (use cost factor 10)
# Default plain-text password is: staff2026  — CHANGE THIS before deploying!
VITE_STAFF_PASSWORD_HASH=$2a$10$REPLACE_WITH_YOUR_BCRYPT_HASH

# ── Program Info (displayed on registration confirmation) ────
VITE_PROGRAM_NAME=2026 Children Vacation Sports Program
VITE_PROGRAM_CONTACT_EMAIL=sports@yourorg.com
VITE_PROGRAM_CONTACT_PHONE=+1 (555) 000-0000
VITE_PAYMENT_INSTRUCTIONS=Please make payment via bank transfer to: ECOBANK Account #:6100083482 Account Title: Monrovia YMCA Branch. 
VITE_PAYMENT_AMOUNT_USD=75

# ── Optional: Google Sheets direct API (read-only analytics) ─
# Only required if you enable the Staff analytics dashboard
# See README Section 7 for setup
VITE_GOOGLE_SHEETS_API_KEY=YOUR_GOOGLE_SHEETS_API_KEY
VITE_GOOGLE_SPREADSHEET_ID=YOUR_SPREADSHEET_ID
